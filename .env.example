# ===== 共享 =====
# Google OAuth Client ID（前端 NextAuth 和后端 verify_oauth2_token 都用同一个值）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===== Database =====
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=app

# ===== Backend =====
# 后端签发 JWT 的密钥（生产用 openssl rand -hex 32 生成）
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS 允许的前端来源
BACKEND_CORS_ORIGINS=http://localhost:3000

# 逗号分隔的 admin 邮箱列表（登录时按此同步用户 role）
ADMIN_EMAILS=wcw8410@gmail.com

# 接收平台费份额的账号邮箱（必须在 ADMIN_EMAILS 内）
PLATFORM_TREASURY_EMAIL=wcw8410@gmail.com

# Fernet master key（生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
BITFINEX_KEY_ENCRYPTION_KEY=replace-me-with-a-real-fernet-key

# ===== Frontend =====
# NextAuth 自身的 session 加密 secret（用 openssl rand -base64 32 生成）
NEXTAUTH_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Client Secret（仅前端 NextAuth 用，后端不需要）
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 前端调用的后端 API 地址（浏览器端用）
NEXT_PUBLIC_API_URL=http://localhost:8000
